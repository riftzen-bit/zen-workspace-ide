{
  "name": "zen-workspace",
  "version": "1.1.5",
  "description": "An isolated, distraction-free command center and elite coding assistant. Orchestrate multiple AI CLI agents side-by-side with peak performance.",
  "main": "./out/main/index.js",
  "author": "riftzen-bit",
  "homepage": "https://github.com/riftzen-bit/zen-workspace-ide",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "cross-env NODE_OPTIONS=\"--no-deprecation\" electron-vite preview",
    "dev": "cross-env NODE_OPTIONS=\"--no-deprecation\" electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "node -e \"const fs=require('fs');const g=[ 'node_modules/node-pty/binding.gyp', 'node_modules/node-pty/deps/winpty/src/winpty.gyp' ];g.forEach(f=>{if(fs.existsSync(f)){fs.writeFileSync(f, fs.readFileSync(f, 'utf8').replace(/'SpectreMitigation': 'Spectre'/g, '\\'SpectreMitigation\\': \\'false\\''));}})\" && electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@google/genai": "^1.48.0",
    "@google/generative-ai": "^0.24.1",
    "@monaco-editor/react": "^4.7.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@types/fs-extra": "^11.0.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/xterm": "^6.0.0",
    "chokidar": "^5.0.0",
    "electron-store": "^11.0.2",
    "framer-motion": "^12.38.0",
    "fs-extra": "^11.3.4",
    "lucide-react": "^1.7.0",
    "node-pty": "^1.1.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "three": "^0.173.0",
    "tw-animate-css": "^1.4.0",
    "yt-search": "^2.13.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/three": "^0.173.0",
    "@types/yt-search": "^2.10.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.2",
    "cross-env": "^10.1.0",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "jsdom": "^29.0.1",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "dompurify": "^3.3.2",
    "redstar": {
      "minimatch": "3.1.5"
    }
  }
}
